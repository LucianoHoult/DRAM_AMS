{
  "topology_initializer": {
    "output_file": "output/init_storage.ic",
    "voltage_levels": {
      "v_high": 1.2,
      "v_low": 0.0
    },
    "path_template": "X_BANK.X_ARRAY_SEC_{sec}.X_MAT_{mat}.X_CELL_{row}_{col}.SN",
    "address_space": {
      "sec": [0],
      "mat": [0],
      "row": [0, 255],
      "col": [0, 63]
    },
    "pattern": "checkerboard"
  },
  "testbench_builder": {
    "output_tb_path": "sim_workspace/top_tb.sp",
    "includes": {
      "tech_lib": "models/finfet_tt.lib",
      "netlist": "output/modified_dram_bank.cdl",
      "stimulus": "output/stimulus.sp",
      "init_cond": "output/init_storage.ic"
    },
    "global_options": [
      "post",
      "probe",
      "nomod",
      "co=132",
      "runlvl=5"
    ],
    "temperature_c": 25,
    "top_instance": {
      "name": "X_DUT",
      "ref_model": "DRAM_BANK",
      "ports": [
        "MWL_EVEN", "MWL_ODD", "SAN_EN", "SAP_EN", "EQ_CTRL",
        "CSL", "LIO", "LIO_B", "VPP", "VSS",
        "BL<0>", "BL<1>", "BL_B<0>", "BL_B<1>"
      ]
    }
  },
  "sim_runner": {
    "execution_mode": "cluster",
    "max_parallel_jobs": 8,
    "timeout_seconds": 7200,
    "local_settings": {
      "executable": "hspice"
    },
    "cluster_settings": {
      "submit_cmd": "asub -q normal -N {job_name}",
      "poll_cmd": "ajob",
      "poll_interval_seconds": 15,
      "job_id_regex": "(?m)^(\\d+)\\s+Submit job successfully",
      "job_done_keyword": "query successfully, no matches."
    }
  }
}
