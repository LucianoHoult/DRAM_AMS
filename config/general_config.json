{
  "project_info": {
    "name": "DRAM_Array_Digital_Twin",
    "target_simulator": "hspice",
    "corner": "TT_25C"
  },
  
  "netlist_rules": {
    "top_subckt": "DRAM_BANK",
    "bus_format": "<>"
  },
  
  "rc_extraction": {
    "unit_metrics": {
      "M1_WL_layer": {"R_per_um": 0.5, "C_per_um": 0.2e-15},
      "M2_BL_layer": {"R_per_um": 0.3, "C_per_um": 0.15e-15},
      "M3_global_layer": {"R_per_um": 0.1, "C_per_um": 0.1e-15}
    },
    "core_array": {
      "WL": {
        "layer": "M1_WL_layer",
        "length_um": 256.0,
        "pi_stages": 4,
        "parent_subckt": "ARRAY_SECTION",
        "driver_inst": "X_SWD_E",
        "target_insts": ["X_MAT_0"]
      },
      "BL": {
        "layer": "M2_BL_layer",
        "length_um": 512.0,
        "pi_stages": 8,
        "parent_subckt": "DRAM_BANK",
        "driver_inst": "X_ARRAY_SEC_0",
        "target_insts": ["X_SA_SEC_0"]
      }
    },
    "global_routes": {
      "CSL": {
        "layer": "M3_global_layer",
        "pi_stages_per_segment": 2,
        "parent_subckt": "DRAM_BANK",
        "driver_inst": "PORT", 
        "topology": [
          {
            "target_inst": "X_SA_SEC_0",
            "segment_length_um": 120.0
          },
          {
            "target_inst": "X_CROSS_HOLE_0", 
            "segment_length_um": 20.0
          },
          {
            "target_inst": "X_SA_SEC_1",
            "segment_length_um": 120.0
          }
        ]
      }
    }
  },

 "reduction_models": {
    "mode": "placeholder",
    "targets": [
      {
        "parent_subckt": "ARRAY_SECTION",
        "inst_name": "X_MAT_1",
        "c_eff_fF": 150.0,
        "i_leak_nA": 10.0,
        "ignore_ports": ["VSS", "VPP", "VDD"]
      },
      {
        "parent_subckt": "SA_SECTION",
        "inst_name": "X_BLSA_1",
        "c_eff_fF": 20.0,
        "i_leak_nA": 2.0,
        "ignore_ports": ["VSS", "VPP"]
      }
    ]
  },

  "pattern_config": {
    "access_location": {
      "bank_idx": 0,
      "row_idx": 128,
      "col_idx": 64
    }
  }

  "topology_initializer": {
    "output_file": "init_storage.ic",
    "voltage_levels": {
      "v_high": 1.2,
      "v_low": 0.0
    },
    "path_template": "X_BANK.X_ARRAY_SEC_{sec}.X_MAT_{mat}.X_CELL_{row}_{col}.SN",
    "address_space": {
      "sec": [0],
      "mat": [0],
      "row": [0, 255],
      "col": [0, 63]
    },
    "pattern": "checkerboard" 
  }
  
  "testbench_builder": {
    "output_tb_path": "sim_workspace/top_tb.sp",
    "includes": {
      "tech_lib": "models/finfet_tt.lib",
      "netlist": "output/modified_dram_bank.cdl",
      "stimulus": "output/stimulus.sp",
      "init_cond": "output/init_storage.ic"
    },
    "global_options": [
      "post", 
      "probe", 
      "nomod", 
      "co=132", 
      "runlvl=5"
    ],
    "temperature_c": 25,
    "top_instance": {
      "name": "X_DUT",
      "ref_model": "DRAM_BANK",
      "ports": [
        "MWL_EVEN", "MWL_ODD", "SAN_EN", "SAP_EN", "EQ_CTRL", 
        "CSL", "LIO", "LIO_B", "VPP", "VSS", 
        "BL<0>", "BL<1>", "BL_B<0>", "BL_B<1>"
      ]
    }
  }

  "sim_runner": {
    "execution_mode": "cluster", 
    "max_parallel_jobs": 8,
    "timeout_seconds": 7200,
    
    "local_settings": {
      "executable": "hspice"
    },
    
    "cluster_settings": {
      "submit_cmd": "asub -q normal -N {job_name}",
      "poll_cmd": "ajob",
      "poll_interval_seconds": 15,
      "job_id_regex": "(?m)^(\\d+)\\s+Submit job successfully",
      "job_done_keyword": "query successfully, no matches."
    }
    
  }
  
}
